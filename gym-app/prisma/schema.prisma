generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Plan {
  id          String   @id @default(cuid())
  userId      String
  name        String
  price       Float
  durationDays Int
  createdAt   DateTime @default(now())
  members     Member[]

  @@index([userId])
}

model Member {
  id        String    @id @default(cuid())
  userId    String
  firstName String
  phone     String
  address   String?
  gender    String?
  endDate   DateTime?
  status    String    @default("Active")
  planId    String?
  plan      Plan?     @relation(fields: [planId], references: [id])
  frozenAt  DateTime?
  image     String?
  createdAt DateTime  @default(now())
  payments  Payment[]
  attendances Attendance[]
  personalRecords PersonalRecord[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, status, endDate])
  @@index([userId, phone])
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  member    Member   @relation(fields: [memberId], references: [id])
  memberId  String
  amount    Float
  mode      String
  status    String   @default("Paid")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, memberId])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
}

model Attendance {
  id          String   @id @default(cuid())
  userId      String
  member      Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  memberId    String?
  memberName  String?
  checkInTime DateTime @default(now())

  @@index([userId])
  @@index([userId, checkInTime])
  @@index([memberId])
  @@index([memberId, checkInTime])
}

model GymUser {
  clerkId     String   @id
  role        String   @default("MEMBER")
  gymOwnerId  String?
  createdAt   DateTime @default(now())

  @@index([gymOwnerId])
}

model Expense {
  id       String   @id @default(cuid())
  userId   String
  title    String
  amount   Float
  category String
  date     DateTime

  @@index([userId])
  @@index([userId, date])
}

model GymConfig {
  userId            String   @id
  gymName           String   @default("Iron Forge Gym")
  ownerName         String?
  gymLat            Float?
  gymLng            Float?
  gymRadius         Float?
  lastStatusCheckAt DateTime?
  testTimeOffset    BigInt?
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

model PersonalRecord {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  exercise  String
  weight    Float
  reps      Int      @default(1)
  date      DateTime @default(now())

  @@index([memberId])
  @@index([memberId, date])
}

